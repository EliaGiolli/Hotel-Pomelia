datasource db {
  provider = "mongodb"
}

generator client {
  provider = "prisma-client-js"
}

model Room {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  capacity    Int
  features    String[]
  images      String[]
}

model Experience {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  iconKey     String
  title       String   @unique
  subtitle    String
  description String
  tags        String[]
  difficulty  String
  duration    String
  image       String
  imageAlt    String
  highlight   Boolean
}

model Dish {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String @unique
  description String
  origin      String
  season      String
  image       String
  imageAlt    String
}

model Workshop {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  iconKey     String
  title       String @unique
  description String
  duration    String
  maxGuests   Int
}

model BookingRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt   DateTime @default(now())
  guestName   String
  guestEmail  String
  checkIn     DateTime
  checkOut    DateTime
  boardType   String   // "Pensione Completa", "Mezza Pensione", "Colazione"
  roomType    String
  notes       String?
  status      String   @default("PENDING") // PENDING, CONFIRMED, REJECTED
}
